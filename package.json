    "mongodb": "^6.0.0",
    "semver": "^7.6.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.8",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
