{
  "name": "documentdb-driver-testing",
  "version": "0.1.0",
  "private": true,
  "description": "Driver validation for DocumentDB and MongoDB-compliant systems",
  "scripts": {
    "build": "tsc",
    "harness": "ts-node src/index.ts",
    "test": "ts-node src/index.ts --adapters nodejs --tests \"tests/**/*.yml\""
  },
  "dependencies": {
